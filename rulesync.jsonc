{
  "$schema": "https://github.com/dyoshikawa/rulesync/releases/latest/download/config-schema.json",
  "targets": ["claudecode"],
  "features": ["skills"],
  "sources": [
    {
      "source": "https://github.com/mattpocock/skills",
      "transport": "git",
      "ref": "main",
      "path": "skills/engineering",
      "skills": ["grill-with-docs", "to-issues", "to-prd", "code-review"]
    }
  ]
}
